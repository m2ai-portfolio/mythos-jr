{
  "name": "@m2ai/mythos-jr",
  "version": "1.0.0",
  "description": "Defensive cybersecurity agent on Claude Agent SDK + A2A Protocol (@a2a-js/sdk), hardened against the failure modes of Claude Mythos Preview.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "mythos-jr": "dist/cli.js"
  },
  "files": [
    "dist",
    ".well-known",
    "system_prompt.md",
    "security-policy.json",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m2ai-portfolio/mythos-jr.git"
  },
  "homepage": "https://github.com/m2ai-portfolio/mythos-jr#readme",
  "bugs": {
    "url": "https://github.com/m2ai-portfolio/mythos-jr/issues"
  },
  "keywords": [
    "security",
    "cybersec",
    "vulnerability-triage",
    "agent",
    "claude",
    "a2a",
    "mythos",
    "defensive-security"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/cli.js 2>/dev/null || true",
    "prepublishOnly": "npm run build",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.94",
    "@a2a-js/sdk": "^0.3.0",
    "express": "^4.21.0",
    "pino": "^9.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
